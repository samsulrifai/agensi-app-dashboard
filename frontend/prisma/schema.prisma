// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  worker
  admin
}

enum ProjectStatus {
  todo
  in_progress
  review
  done
  archived
}

enum Priority {
  low
  medium
  high
  critical
}

enum TaskStatus {
  todo
  in_progress
  review
  done
}

enum InvoiceStatus {
  pending
  approved
  rejected
  paid
}

enum MilestoneStatus {
  pending
  completed
}

enum NotificationType {
  deadline_reminder
  project_assigned
  invoice_submitted
  invoice_approved
  invoice_rejected
  rating_received
  task_status_changed
}

// ─── Core Tables ────────────────────────────────────────────────────────────

model User {
  id          String    @id @default(uuid())
  email       String    @unique
  passwordHash String   @map("password_hash")
  fullName    String    @map("full_name")
  role        Role
  avatarUrl   String?   @map("avatar_url")
  phone       String?
  skills      String[]  @default([])
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  lastLoginAt DateTime? @map("last_login_at")

  // Relations
  adminProjects    Project[]        @relation("AdminProjects")
  projectWorkers   ProjectWorker[]
  assignedTasks    Task[]           @relation("AssignedTasks")
  timeLogs         TimeLog[]
  workerInvoices   Invoice[]        @relation("WorkerInvoices")
  approvedInvoices Invoice[]        @relation("ApprovedInvoices")
  workerRatings    Rating[]         @relation("WorkerRatings")
  adminRatings     Rating[]         @relation("AdminRatings")
  notifications    Notification[]
  attachments      Attachment[]
  auditLogs        AuditLog[]

  @@map("users")
}

model Project {
  id          String        @id @default(uuid())
  title       String
  description String?
  clientName  String        @map("client_name")
  budget      Decimal       @db.Decimal(15, 2)
  status      ProjectStatus @default(todo)
  priority    Priority      @default(medium)
  deadline    DateTime
  adminId     String        @map("admin_id")
  createdAt   DateTime      @default(now()) @map("created_at")
  completedAt DateTime?     @map("completed_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  // Relations
  admin          User            @relation("AdminProjects", fields: [adminId], references: [id])
  projectWorkers ProjectWorker[]
  tasks          Task[]
  invoices       Invoice[]
  ratings        Rating[]
  milestones     Milestone[]
  attachments    Attachment[]

  @@map("projects")
}

model ProjectWorker {
  id            String  @id @default(uuid())
  projectId     String  @map("project_id")
  workerId      String  @map("worker_id")
  roleInProject String? @map("role_in_project")
  joinedAt      DateTime @default(now()) @map("joined_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  worker  User    @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@unique([projectId, workerId])
  @@map("project_workers")
}

model Task {
  id             String     @id @default(uuid())
  projectId      String     @map("project_id")
  assignedTo     String?    @map("assigned_to")
  title          String
  description    String?
  status         TaskStatus @default(todo)
  deadline       DateTime?
  estimatedHours Decimal?   @db.Decimal(6, 2) @map("estimated_hours")
  actualHours    Decimal?   @db.Decimal(6, 2) @map("actual_hours")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  worker     User?       @relation("AssignedTasks", fields: [assignedTo], references: [id])
  timeLogs   TimeLog[]
  attachments Attachment[]

  @@map("tasks")
}

model TimeLog {
  id              String    @id @default(uuid())
  taskId          String    @map("task_id")
  workerId        String    @map("worker_id")
  startedAt       DateTime  @map("started_at")
  endedAt         DateTime? @map("ended_at")
  durationMinutes Int?      @map("duration_minutes")
  notes           String?

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  worker User @relation(fields: [workerId], references: [id])

  @@map("time_logs")
}

model Invoice {
  id              String        @id @default(uuid())
  workerId        String        @map("worker_id")
  projectId       String        @map("project_id")
  amount          Decimal       @db.Decimal(15, 2)
  status          InvoiceStatus @default(pending)
  invoiceDate     DateTime      @default(now()) @map("invoice_date")
  dueDate         DateTime      @map("due_date")
  notes           String?
  rejectionReason String?       @map("rejection_reason")
  approvedBy      String?       @map("approved_by")
  approvedAt      DateTime?     @map("approved_at")
  attachmentUrl   String?       @map("attachment_url")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  worker   User    @relation("WorkerInvoices", fields: [workerId], references: [id])
  project  Project @relation(fields: [projectId], references: [id])
  approver User?   @relation("ApprovedInvoices", fields: [approvedBy], references: [id])

  @@map("invoices")
}

model Rating {
  id                 String  @id @default(uuid())
  workerId           String  @map("worker_id")
  adminId            String  @map("admin_id")
  projectId          String  @map("project_id")
  scoreDeadline      Decimal @db.Decimal(3, 2) @map("score_deadline")
  scoreQuality       Decimal @db.Decimal(3, 2) @map("score_quality")
  scoreCommunication Decimal @db.Decimal(3, 2) @map("score_communication")
  overallScore       Decimal @db.Decimal(3, 2) @map("overall_score")
  reviewText         String? @map("review_text")
  createdAt          DateTime @default(now()) @map("created_at")

  worker  User    @relation("WorkerRatings", fields: [workerId], references: [id])
  admin   User    @relation("AdminRatings", fields: [adminId], references: [id])
  project Project @relation(fields: [projectId], references: [id])

  @@map("ratings")
}

model Milestone {
  id        String          @id @default(uuid())
  projectId String          @map("project_id")
  title     String
  dueDate   DateTime        @map("due_date")
  status    MilestoneStatus @default(pending)
  amount    Decimal?        @db.Decimal(15, 2)
  createdAt DateTime        @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("milestones")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  body      String
  isRead    Boolean          @default(false) @map("is_read")
  metadata  Json?
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Attachment {
  id          String   @id @default(uuid())
  projectId   String?  @map("project_id")
  taskId      String?  @map("task_id")
  uploadedBy  String   @map("uploaded_by")
  fileUrl     String   @map("file_url")
  fileName    String   @map("file_name")
  sizeBytes   Int      @map("size_bytes")
  mimeType    String   @map("mime_type")
  createdAt   DateTime @default(now()) @map("created_at")

  project Project? @relation(fields: [projectId], references: [id])
  task    Task?    @relation(fields: [taskId], references: [id])
  uploader User    @relation(fields: [uploadedBy], references: [id])

  @@map("attachments")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  action    String
  entity    String
  entityId  String?  @map("entity_id")
  oldValue  Json?    @map("old_value")
  newValue  Json?    @map("new_value")
  ipAddress String?  @map("ip_address")
  timestamp DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}
