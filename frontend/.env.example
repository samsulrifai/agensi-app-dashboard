# ─── Database (Neon) ────────────────────────────────────────────────────────
# Gunakan URL pooled untuk query runtime (melalui PgBouncer)
DATABASE_URL="postgresql://user:pass@ep-xxx.ap-southeast-1.aws.neon.tech/dbname?sslmode=require&pgbouncer=true"

# Gunakan URL direct HANYA untuk prisma migrate dan prisma db push
DATABASE_URL_UNPOOLED="postgresql://user:pass@ep-xxx.ap-southeast-1.aws.neon.tech/dbname?sslmode=require"

# ─── Authentication (NextAuth.js) ────────────────────────────────────────────
# Generate dengan: openssl rand -base64 32
AUTH_SECRET="your-32-char-secret-here"

# Base URL aplikasi (tanpa trailing slash)
NEXTAUTH_URL="http://localhost:3000"

# ─── Supabase Storage ────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
# JANGAN expose ke client — hanya untuk server-side
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ─── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY="re_your_resend_api_key"

# ─── App Config ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Optional: Sentry Error Tracking ────────────────────────────────────────
# SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"

# ─── Optional: Vercel KV (Redis) ─────────────────────────────────────────────
# KV_URL="redis://..."
# KV_REST_API_URL="https://..."
# KV_REST_API_TOKEN="..."
