# ─────────────────────────────────────────────────────────────────────────────
# Agency App — Environment Variables Template
# Salin file ini menjadi .env.local dan isi nilainya
# cp .env.example .env.local
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database (Neon PostgreSQL) ───────────────────────────────────────────────
# URL pooled (via PgBouncer) — gunakan untuk runtime queries
DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.ap-southeast-1.aws.neon.tech/dbname?sslmode=require&pgbouncer=true&channel_binding=require"

# URL direct — HANYA untuk prisma migrate dan prisma db push
DATABASE_URL_UNPOOLED="postgresql://user:pass@ep-xxx.ap-southeast-1.aws.neon.tech/dbname?sslmode=require&channel_binding=require"

# ─── Authentication (NextAuth.js v5) ──────────────────────────────────────────
# Generate dengan: openssl rand -base64 32
AUTH_SECRET="your-32-char-secret-here"

# WAJIB: Base URL aplikasi (tanpa trailing slash)
NEXTAUTH_URL="http://localhost:3000"

# ─── Supabase Storage ─────────────────────────────────────────────────────────
# Dari Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# JANGAN expose ke client — hanya untuk server-side API routes
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Dari https://resend.com/api-keys
RESEND_API_KEY="re_your_resend_api_key"

# ─── App Config ───────────────────────────────────────────────────────────────
# Base URL yang akan tampil di link email (harus HTTPS di production)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Production Seed (optional) ──────────────────────────────────────────────
# Digunakan oleh: ts-node prisma/seed-production.ts
# ADMIN_EMAIL="admin@yourcompany.com"
# ADMIN_PASSWORD="change-me-min-12-chars"

# ─── Optional: Sentry Error Tracking ─────────────────────────────────────────
# SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"
# NEXT_PUBLIC_SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"

# ─── Optional: Vercel KV (Redis) untuk distributed cache ─────────────────────
# KV_URL="redis://..."
# KV_REST_API_URL="https://..."
# KV_REST_API_TOKEN="..."

# ─────────────────────────────────────────────────────────────────────────────
# PANDUAN VERCEL DEPLOYMENT:
# 1. Buat project di Vercel, connect ke GitHub repo ini
# 2. Di Vercel Dashboard → Settings → Environment Variables, tambahkan:
#    - DATABASE_URL        (dari Neon: Connection String > Pooled)
#    - AUTH_SECRET         (generate: openssl rand -base64 32)
#    - NEXTAUTH_URL        (https://yourdomain.vercel.app)
#    - NEXT_PUBLIC_APP_URL (https://yourdomain.vercel.app)
#    - NEXT_PUBLIC_SUPABASE_URL
#    - NEXT_PUBLIC_SUPABASE_ANON_KEY
#    - SUPABASE_SERVICE_ROLE_KEY
#    - RESEND_API_KEY
# 3. Deploy — build command sudah di vercel.json: "prisma generate && next build"
# ─────────────────────────────────────────────────────────────────────────────
